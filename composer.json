{
    "name": "erenav/laravel-icalendar",
    "description": "Laravel integration for erenav/icalendar — build, serve, and parse iCalendar feeds in Laravel.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "icalendar", "ical", "ics", "calendar", "rfc5545", "feed"],
    "homepage": "https://github.com/erenav/laravel-icalendar",
    "authors": [
        {
            "name": "erenav",
            "homepage": "https://github.com/erenav"
        }
    ],
    "require": {
        "php": ">=8.3",
        "erenav/icalendar": ">=0.2 <2.0",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/contracts": "^11.0 || ^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "Erenav\\LaravelICalendar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Erenav\\LaravelICalendar\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Erenav\\LaravelICalendar\\ICalendarServiceProvider"
            ],
            "aliases": {
                "ICalendar": "Erenav\\LaravelICalendar\\Facades\\ICalendar"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=512M",
        "format": "pint",
        "lint": "pint --test",
        "check": [
            "@lint",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
